# Docker / Compose
APP_ENV=dev
BACKEND_PORT=8000
DB_PORT=5432

# PostgreSQL
POSTGRES_VERSION=16
POSTGRES_USER=foliode
POSTGRES_PASSWORD=foliode
POSTGRES_DB=foliode
DATABASE_URL=postgresql://foliode:foliode@database:5432/foliode?serverVersion=16&charset=utf8

# Backend
APP_SECRET=change-me-in-production
MAILER_DSN=smtp://mailhog:1025
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
CORS_ALLOW_ORIGIN=^https?://(localhost|127\\.0\\.1)(:[0-9]+)?$
VAR_DUMPER_SERVER=127.0.0.1:9912
JWT_PASSPHRASE=change-this-passphrase
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
